        {
            "type": "text",
            "text": "```yaml\nquest:\n  parts:\n    # часть 1: получение задания\n    resource_to_deliver:\n      dialogs:\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Приветствую, путник! Мне прислали срочную весточку из Деревни Речных Лугов.\"\n        - speaker: \"Игрок\"\n          remark: \"Что-то случилось, мастер Гаррик? Нужна моя помощь?\"\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Местному лекарю Лире не хватает сырья для ковки новых медицинских инструментов.\"\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Отправляйся в Подорожниковый Бор и добывай там железо. Его нужно немедленно доставить ей.\"\n        - speaker: \"Игрок\"\n          remark: \"Я справлюсь. Сколько руды потребуется для работы?\"\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Пяти кусков железной руды будет достаточно. Поспеши, от этого зависят жизни!\"\n      character: \"Гаррик Кузнец\"\n      resource: \"Железо\"\n      amount: 5\n\n    # часть 2: встреча с противником после добычи ресурса\n    enemy_to_face:\n      dialogs:\n        - speaker: \"Гоблин-вор\"\n          remark: \"Стой, человечишка! Твой мешок подозрительно тяжело звенит!\"\n        - speaker: \"Игрок\"\n          remark: \"Отойди, это всего лишь руда для деревенского лекаря.\"\n        - speaker: \"Гоблин-вор\"\n          remark: \"Всего лишь руда? Ха! Железо на черном рынке стоит кучу золотых монет!\"\n        - speaker: \"Игрок\"\n          remark: \"Я не позволю вам забрать груз. Приготовьтесь к честному бою!\"\n        - speaker: \"Гоблин-вор\"\n          remark: \"Хватай его, парни! Железо сегодня будет нашим, а он пойдет на корм крысам!\"\n      enemy: \"Гоблин-вор\"\n      amount: 2\n\n    # часть 3: доставка ресурсов\n    destination:\n      dialogs:\n        - speaker: \"Лира Лекарь\"\n          remark: \"О, наконец-то! Я уже начала опасаться, что поставка из столицы задержится.\"\n        - speaker: \"Игрок\"\n          remark: \"Мастер Гаррик просил передать вам это железо. Вот, все пять кусков.\"\n        - speaker: \"Лира Лекарь\"\n          remark: \"Благодарю тебя! Теперь я смогу изготовить новые ланцеты для операций.\"\n        - speaker: \"Лира Лекарь\"\n          remark: \"Ты выглядишь запыхавшимся. В пути возникли какие-то трудности?\"\n        - speaker: \"Игрок\"\n          remark: \"На меня напала банда гоблинов-воров, но им не удалось отобрать груз.\"\n        - speaker: \"Лира Лекарь\"\n          remark: \"Твой деревянный меч едва держится. В награду за храбрость возьми этот — он гораздо крепче.\"\n      character_to_deliver: \"Лира Лекарь\"\n\n  objective_description: \"Соберите 5 единиц железной руды в локации Подорожниковый Бор и доставьте их Лире Лекарю в Деревню Речных Лугов.\"\n  \n  reward:\n    item_name: \"Каменный меч\"\n\n  explanation:\n    resource_to_deliver:\n      dialogs: \"Диалоги построены на взаимодействии с кузнецом из столицы, который дает логичное задание на сбор металла для профессиональных нужд.\"\n      character: \"Гаррик Кузнец выбран как отправная точка, так как он находится в начальной локации (Столица) и связан с металлургией.\"\n      resource: \"Железо выбрано, так как для его добычи требуется кирка 1 ранга, которая уже есть у игрока 1 уровня.\"\n      amount: \"Количество 5 является сбалансированным для первого квеста по сбору ресурсов.\"\n\n    enemy_to_face:\n      dialogs: \"Диалоги отражают классический конфликт: воры пытаются перехватить ценный ресурс, который игрок несет лекарю.\"\n      enemy: \"Гоблин-вор выбран как противник 1 ранга, что соответствует текущему уровню игрока и его снаряжению.\"\n      amount: \"Двое противников создают умеренную сложность, позволяя игроку применить оружие по нескольким целям.\"\n\n    destination:\n      dialogs: \"Диалоги завершают сюжетную арку доставки, подчеркивая важность принесенного ресурса для мирных жителей.\"\n      character_to_deliver: \"Лира Лекарь выбрана, так как она официально принимает Железо согласно игровым данным и находится в другой локации.\"\n```",
