            "type": "text",
            "text": "```yaml\nquest:\n  parts:\n    # часть 1: получение задания\n    resource_to_deliver:\n      dialogs:\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Эй, новичок! Вижу, у тебя в руках верная деревянная кирка. Есть дело.\"\n        - speaker: \"Игрок\"\n          remark: \"Привет, Гаррик. Что за дело? Я как раз искал, где применить инструмент.\"\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Лире из Деревни Речных Лугов срочно нужны материалы для ковки новых инструментов.\"\n        - speaker: \"Игрок\"\n          remark: \"Я готов помочь. Что именно мне нужно найти?\"\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Добудь 5 единиц Железа. В наших краях его в достатке, если знать, где копать.\"\n        - speaker: \"Игрок\"\n          remark: \"Хорошо, 5 кусков Железа. А куда их потом доставить?\"\n        - speaker: \"Гаррик Кузнец\"\n          remark: \"Отправляйся прямиком в Деревню Речных Лугов и разыщи там Лиру Лекаря.\"\n      character: \"Гаррик Кузнец\"\n      resource: \"Железо\"\n      amount: 5\n\n    # часть 2: встреча с противником после добычи ресурса\n    enemy_to_face:\n      dialogs:\n        - speaker: \"Игрок\"\n          remark: \"Фух, кажется, это последний кусок железа в этой жиле.\"\n        - speaker: \"Пещерная крыса\"\n          remark: \"*Громкий писк и шуршание в темноте пещеры*\"\n        - speaker: \"Игрок\"\n          remark: \"Кто здесь? Покажись!\"\n        - speaker: \"Пещерная крыса\"\n          remark: \"*Громадная крыса скалится, ее глаза сверкают в лунном свете*\"\n        - speaker: \"Игрок\"\n          remark: \"Ты не получишь мою добычу, тварь! Придется испытать мой меч в деле.\"\n        - speaker: \"Пещерная крыса\"\n          remark: \"*Крыса совершает яростный прыжок, целясь в ноги игрока*\"\n      enemy: \"Пещерная крыса\"\n      amount: 1\n\n    # часть 3: доставка ресурсов\n    destination:\n      dialogs:\n        - speaker: \"Лира Лекарь\"\n          remark: \"Добрый день, путник. Ты выглядишь так, будто проделал долгий путь.\"\n        - speaker: \"Игрок\"\n          remark: \"Здравствуйте. Я от Гаррика из Столицы. Принес посылку, которую вы ждали.\"\n        - speaker: \"Лира Лекарь\"\n          remark: \"Ах, это должно быть Железо! Гаррик всегда присылает только лучших помощников.\"\n        - speaker: \"Игрок\"\n          remark: \"Да, вот ваши 5 единиц руды. Пришлось немного попотеть, добывая их.\"\n        - speaker: \"Лира Лекарь\"\n          remark: \"Прекрасно. Теперь я смогу изготовить новые скальпели и лопаты для деревни.\"\n        - speaker: \"Игрок\"\n          remark: \"Рад был помочь общему делу.\"\n        - speaker: \"Лира Лекарь\"\n          remark: \"Твой деревянный меч выглядит совсем ненадежным. Возьми этот, он тебе нужнее.\"\n      character_to_deliver: \"Лира Лекарь\"\n\n  objective_description: \"Добудьте 5 единиц Железа с помощью кирки и доставьте их Лире Лекарю в Деревню Речных Лугов по поручению Гаррика Кузнеца.\"\n  \n  reward:\n    item_name: \"Каменный меч\"\n\n  explanation:\n    resource_to_deliver:\n      dialogs: \"Диалоги из 7 реплик вводят игрока в курс дела, обозначают цель и конечный пункт доставки, соблюдая характер персонажа.\"\n      character: \"Гаррик Кузнец выбран как начальный NPC в Королевской столице, что логично для игрока 1 уровня.\"\n      resource: \"Железо выбрано, так как у игрока есть Деревянная кирка 1 ранга, способная добывать ресурсы с min_instrument_rank: 1.\"\n      amount: \"5 единиц — сбалансированное количество для стартового квеста.\"\n\n    enemy_to_face:\n      dialogs: \"6 реплик создают атмосферу внезапной угрозы в процессе выполнения задания.\"\n      enemy: \"Пещерная крыса — подходящий противник 1 ранга для игрока без брони, имеющего 100 единиц здоровья.\"\n      amount: \"1 противник, чтобы игрок мог гарантированно победить, используя деревянный меч (2 урона).\"\n\n    destination:\n      dialogs: \"7 реплик завершают сюжетную арку, обосновывают полезность принесенного ресурса и выдачу награды.\"\n      character_to_deliver: \"Лира Лекарь выбрана, так как она принимает Железо и находится в локации Деревня Речных Лугов.\"\n```",
            "extras": {
                "signature": ""
            }
